# ── Backend JOVKEY-1XBET — variables d'environnement ───────────────
# Copier en .env (jamais commité) et remplir avec des valeurs FORTES en prod.

# Base de données (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Secret de signature JWT — OBLIGATOIRE en prod (chaîne aléatoire longue).
JWT_SECRET="change-moi-par-une-chaine-aleatoire-tres-longue"
JWT_EXPIRES_IN="7d"

# Clé interne consommée par le moteur d'analyse Python (doit matcher analysis-engine/.env)
ANALYSIS_API_KEY="change-moi-cle-interne"

# Mot de passe initial du superadmin (créé par `npm run seed:prod`)
SUPERADMIN_EMAIL="admin@ton-domaine.com"
SUPERADMIN_BOOTSTRAP_PASSWORD="change-moi-mot-de-passe-fort"

# CORS : domaine(s) du frontend autorisés (séparés par des virgules)
FRONTEND_ORIGIN="https://ton-domaine.com"

# Stockage des médias uploadés (images/vidéos CMS) — volume PERSISTANT en prod
UPLOAD_DIR="/data/uploads"

# ── Cloudinary (upload direct des vidéos CMS depuis le navigateur admin) ──
# Sans ces 3 clés, l'upload vidéo Cloudinary du panel admin est indisponible
# (le lien YouTube reste utilisable). Récupérables sur dashboard.cloudinary.com.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── FedaPay (paiements automatiques : Mobile Money, carte…) ──
# Sans FEDAPAY_SECRET_KEY, le service tombe en mode simulation locale (aucun appel réel).
# Passage en prod : FEDAPAY_ENVIRONMENT=live + tes clés pk_live_/sk_live_ (rien d'autre à changer).
FEDAPAY_ENVIRONMENT=sandbox
NEXT_PUBLIC_FEDAPAY_PUBLIC_KEY=""
FEDAPAY_SECRET_KEY=""
# Secret de signature du webhook (dashboard FedaPay > Webhooks > Ajouter un webhook)
FEDAPAY_WEBHOOK_SECRET=""
# URL PUBLIQUE du backend (pour le webhook FedaPay) et du frontend (page de retour)
API_PUBLIC_URL="https://api.ton-domaine.com"
FRONTEND_URL="https://ton-domaine.com"

# Port
PORT=4000
NODE_ENV=production
