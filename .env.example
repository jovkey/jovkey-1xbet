# ─── Base de données ──────────────────────────────────────────────
POSTGRES_USER=jovkey
POSTGRES_PASSWORD=jovkey_secret
POSTGRES_DB=jovkey1xbet
DATABASE_URL=postgresql://jovkey:jovkey_secret@postgres:5432/jovkey1xbet?schema=public

# ─── Redis (Celery broker) ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Backend NestJS ───────────────────────────────────────────────
JWT_SECRET=change-me-in-production-please-32chars-min
JWT_EXPIRES_IN=7d
PORT=4000
# Route admin fantôme (doit matcher NEXT_PUBLIC_ADMIN_ROUTE côté front)
ADMIN_SECRET_ROUTE=jov-secure-control-888
SUPERADMIN_BOOTSTRAP_PASSWORD=jovkey-super-888

# ─── Frontend Next.js ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ADMIN_ROUTE=jov-secure-control-888
NEXT_PUBLIC_PROMO_CODE=JOVKEY

# ─── Moteur d'analyse Python ──────────────────────────────────────
ANALYSIS_API_KEY=internal-analysis-key
BACKEND_INTERNAL_URL=http://backend:4000
