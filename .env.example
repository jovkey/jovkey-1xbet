# ─── Base de données ──────────────────────────────────────────────
POSTGRES_USER=jovkey
POSTGRES_PASSWORD=jovkey_secret
POSTGRES_DB=jovkey1xbet
DATABASE_URL=postgresql://jovkey:jovkey_secret@postgres:5432/jovkey1xbet?schema=public

# ─── Redis (Celery broker) ────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Backend NestJS ───────────────────────────────────────────────
JWT_SECRET=change-me-in-production-please-32chars-min
JWT_EXPIRES_IN=7d
PORT=4000
# OBLIGATOIRE en hébergement réel : domaine EXACT du frontend déployé (schéma inclus).
# Sans ça, le backend refuse de démarrer (protection CORS pour l'auth par cookie httpOnly).
FRONTEND_ORIGIN=https://ton-domaine.com
# URL publique du backend (webhook FedaPay) et du frontend (page de retour paiement) :
API_PUBLIC_URL=https://api.ton-domaine.com
FRONTEND_URL=https://ton-domaine.com
ADMIN_SECRET_ROUTE=jov-secure-control-888
SUPERADMIN_EMAIL=admin@ton-domaine.com
SUPERADMIN_BOOTSTRAP_PASSWORD=change-moi-mot-de-passe-fort
# ── FedaPay (laisser vide = mode simulation locale sans vraie transaction) ──
FEDAPAY_ENVIRONMENT=sandbox
FEDAPAY_SECRET_KEY=
FEDAPAY_WEBHOOK_SECRET=
# ── Cloudinary (upload vidéo CMS ; laisser vide = fonctionnalité désactivée) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Frontend Next.js ─────────────────────────────────────────────
# ⚠️ CRITIQUE : ces valeurs NEXT_PUBLIC_* sont figées dans le bundle JS au moment du
# `docker build` (docker-compose.yml les passe en --build-arg, PAS en env runtime).
# Si NEXT_PUBLIC_API_URL ne pointe pas vers le VRAI domaine public du backend, le
# frontend hébergé continuera d'appeler localhost:4000 depuis le navigateur des
# visiteurs → inscription/connexion échouent silencieusement une fois déployé.
NEXT_PUBLIC_API_URL=https://api.ton-domaine.com
NEXT_PUBLIC_PROMO_CODE=JOVKEY

# ─── Moteur d'analyse Python ──────────────────────────────────────
ANALYSIS_API_KEY=internal-analysis-key
BACKEND_INTERNAL_URL=http://backend:4000
SPORTS_PROVIDER=sofascore
RAPIDAPI_KEY=
RAPIDAPI_HOST=sofascore.p.rapidapi.com
